---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { cv } from '../data/cv';
---

<Layout title="CV | Luis" description="Curriculum vitae of Luis">
	<Navbar />

	<section class="pt-32 pb-24 px-6 min-h-screen">
		<div class="max-w-4xl mx-auto">
			<header class="mb-12">
				<h1 class="text-4xl font-bold text-white mb-2">
					Curriculum Vitae<span class="text-[var(--color-accent)]">.</span>
				</h1>
				<div class="w-12 h-1 bg-[var(--color-accent)] rounded mb-6"></div>

				<div class="flex flex-wrap items-center gap-4 text-sm text-gray-400">
					<span class="flex items-center gap-2">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
						</svg>
						{cv.name}
					</span>
					<span class="flex items-center gap-2">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
						</svg>
						{cv.title}
					</span>
					<span class="flex items-center gap-2">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
						</svg>
						{cv.location}
					</span>
				</div>
			</header>

			<div class="space-y-12">
				<div>
					<h2 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
						<span class="w-8 h-[2px] bg-[var(--color-accent)]"></span>
						Summary
					</h2>
					<p class="text-gray-400 leading-relaxed pl-10">{cv.summary}</p>
				</div>

				<div>
					<h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
						<span class="w-8 h-[2px] bg-[var(--color-accent)]"></span>
						Experience
					</h2>
					<div class="space-y-8 pl-10">
						{cv.experience.map((exp) => (
							<div class="relative">
								<div class="absolute left-[-28px] top-2 w-3 h-3 rounded-full bg-[var(--color-accent)]/20 border-2 border-[var(--color-accent)]"></div>
								<div class="absolute left-[-23px] top-5 bottom-[-32px] w-[2px] bg-[var(--color-border)]"></div>
								<h3 class="text-lg font-medium text-white">{exp.role}</h3>
								<p class="text-[var(--color-accent-light)] text-sm mb-2">{exp.company} &middot; {exp.period}</p>
								<p class="text-gray-400 text-sm leading-relaxed mb-3">{exp.description}</p>
								<div class="flex flex-wrap gap-2">
									{exp.technologies.map((tech) => (
										<span class="px-2 py-0.5 text-xs font-mono text-gray-500 bg-[var(--color-surface)] border border-[var(--color-border)] rounded">
											{tech}
										</span>
									))}
								</div>
							</div>
						))}
					</div>
				</div>

				<div>
					<h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
						<span class="w-8 h-[2px] bg-[var(--color-accent)]"></span>
						Education
					</h2>
					<div class="space-y-6 pl-10">
						{cv.education.map((edu) => (
							<div class="relative">
								<div class="absolute left-[-28px] top-2 w-3 h-3 rounded-full bg-[var(--color-accent)]/20 border-2 border-[var(--color-accent)]"></div>
								<h3 class="text-lg font-medium text-white">{edu.degree}</h3>
								<p class="text-[var(--color-accent-light)] text-sm mb-1">{edu.institution} &middot; {edu.period}</p>
								{edu.description && <p class="text-gray-400 text-sm">{edu.description}</p>}
							</div>
						))}
					</div>
				</div>

				<div>
					<h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
						<span class="w-8 h-[2px] bg-[var(--color-accent)]"></span>
						Languages
					</h2>
					<div class="pl-10 flex flex-wrap gap-4">
						{cv.languages.map((lang) => (
							<div class="px-4 py-2 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)]">
								<span class="text-white text-sm font-medium">{lang.name}</span>
								<span class="text-gray-500 text-xs ml-2">{lang.level}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
