---
import { projects } from '../data/projects';
---

<section id="projects" class="py-24 px-6">
	<div class="max-w-5xl mx-auto">
		<h2 class="text-3xl font-bold text-white mb-2">
			Projects<span class="text-[var(--color-accent)]">.</span>
		</h2>
		<div class="w-12 h-1 bg-[var(--color-accent)] rounded mb-10"></div>

		<div class="space-y-8">
			{projects.map((project) => (
				<article class="group p-6 md:p-8 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/30 transition-all duration-300 hover:shadow-lg hover:shadow-[var(--color-accent)]/5">
					<div class="flex items-start justify-between mb-4">
						<div>
							<h3 class="text-xl font-semibold text-white group-hover:text-[var(--color-accent-light)] transition-colors duration-200">
								{project.title}
							</h3>
							<div class="flex items-center gap-3 mt-1">
								<span class="text-sm text-gray-500">{project.year}</span>
								<span class={`text-xs px-2 py-0.5 rounded-full ${
									project.status === 'Live' ? 'bg-emerald-500/10 text-emerald-400' :
									project.status === 'In Progress' ? 'bg-amber-500/10 text-amber-400' :
									'bg-gray-500/10 text-gray-400'
								}`}>
									{project.status}
								</span>
							</div>
						</div>
						<div class="flex items-center gap-3">
							{project.repo && (
								<a
									href={project.repo}
									class="text-sm text-gray-400 hover:text-white transition-colors"
									target="_blank"
									aria-label={`${project.title} repository`}
								>
									<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
										<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
									</svg>
								</a>
							)}
							{project.link && (
								<a
									href={project.link}
									class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-light)] transition-colors"
								>
									View &rarr;
								</a>
							)}
						</div>
					</div>

					<p class="text-gray-400 leading-relaxed mb-5">{project.description}</p>

					{project.architecture && (
						<div class="mb-5">
							<p class="text-xs text-gray-500 uppercase tracking-wider mb-3 font-medium">Architecture</p>
							<ul class="space-y-2">
								{project.architecture.map((item) => (
									<li class="flex items-start gap-2 text-sm text-gray-400">
										<span class="text-[var(--color-accent)] mt-1 shrink-0">&#9656;</span>
										<span>{item}</span>
									</li>
								))}
							</ul>
						</div>
					)}

					<div class="flex flex-wrap gap-2">
						{project.tags.map((tag) => (
							<span class="px-3 py-1 text-xs font-mono text-gray-400 bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-full">
								{tag}
							</span>
						))}
					</div>
				</article>
			))}
		</div>
	</div>
</section>
